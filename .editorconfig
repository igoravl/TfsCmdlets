root = true

[*.cs]

dotnet_diagnostic.IDE0056.severity = none
dotnet_diagnostic.IDE0057.severity = none

# Verify settings
[*.{received,verified}.{json,txt,xml,cs}]
charset = utf-8-bom
end_of_line = lf
indent_size = unset
indent_style = unset
insert_final_newline = false
tab_width = unset
trim_trailing_whitespace = false