<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
    <Package Name="$(var.PRODUCTNAME)" Language="1033" Version="$(var.PRODUCTVERSION)"
        Manufacturer="$(var.AUTHOR)" UpgradeCode="66e39e8c-5e29-47ca-b2c0-142978831346"
        InstallerVersion="405" Scope="perUser">
        <SummaryInformation Description="$(var.DESCRIPTION)" />
        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <Media Id="1" Cabinet="Setup.cab" EmbedCab="yes" />

        <!--Properties-->

        <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
        <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
        <Property Id="WixAppFolder" Value="WixPerUserFolder" />

        <WixVariable Id="WixUISupportPerUser" Value="1" />
        <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceDir)License.rtf" />
        <WixVariable Id="WixUIDialogBmp" Value="$(var.SourceDir)Wix-01.bmp" />
        <WixVariable Id="WixUIBannerBmp" Value="$(var.SourceDir)Wix-02.bmp" />

        <!--UI Settings-->

        <ui:WixUI Id="WixUI_InstallDir" />
        <Icon Id="ProductIcon" SourceFile="$(var.SourceDir)TfsCmdletsShell.ico" />

        <!--Dependency detection-->

        <Property Id="POWERSHELLVERSION3" Secure="yes">
            <RegistrySearch Id="PowerShellVersion3Search" Root="HKLM"
                Key="SOFTWARE\Microsoft\PowerShell\3\PowerShellEngine" Name="PowerShellVersion"
                Type="raw" />
        </Property>

        <!--Windows Terminal detection-->

        <Property Id="WINDOWSTERMINAL" Secure="yes">
            <RegistrySearch Id="WindowsTerminalSearch" Root="HKCU"
                Key="Software\Microsoft\Windows\CurrentVersion\App Paths\wt.exe"
                Type="raw" />
        </Property>

        <!--Directories and Components-->

        <StandardDirectory Id="LocalAppDataFolder">
            <Directory Id="INSTALLFOLDER" Name="$(var.PRODUCTNAME)">
                <Component Id="SetModulePath" Guid="{CC97272C-1234-46A5-AB61-5A4588C8D924}"
                    KeyPath="yes">
                    <!-- Explicitly include the CurrentUser modules path to prevent Windows PowerShell
                         from dropping it. When PSModulePath exists in the registry, WinPS does NOT
                         prepend the default CurrentUser path (~\Documents\WindowsPowerShell\Modules),
                         so we must preserve it here. Duplicates in PSModulePath are harmless. -->
                    <Environment Id="Env_ModulePath" Action="set" Name="PSModulePath" Part="last"
                        Separator=";" System="no" Permanent="no"
                        Value="[PersonalFolder]WindowsPowerShell\Modules;[INSTALLFOLDER]" />
                </Component>
                <Directory Id="ModuleFolder" Name="TfsCmdlets">
                    <Files Include="$(SourceDir)/**" />
                </Directory>
            </Directory>
        </StandardDirectory>
        
        <!-- Windows Terminal profile fragments (deployed to WT's expected location) -->
        <StandardDirectory Id="LocalAppDataFolder">
            <Directory Id="MicrosoftDir" Name="Microsoft">
                <Directory Id="WindowsTerminalDir" Name="Windows Terminal">
                    <Directory Id="FragmentsDir" Name="Fragments">
                        <Directory Id="TfsCmdletsFragmentsDir" Name="TfsCmdlets">
                            <Component Id="WTFragmentWinPS" Guid="{D3E4F5A6-7B8C-9D0E-F1A2-B3C4D5E6F7A8}"
                                Condition="WINDOWSTERMINAL">
                                <File Id="WTFragmentWinPSFile"
                                    Source="$(var.SourceDir)_Fragments\AzureDevOpsShell-WinPS.json" />
                                <RemoveFolder Id="RemoveTfsCmdletsFragmentsDir" On="uninstall"
                                    Directory="TfsCmdletsFragmentsDir" />
                            </Component>
                            <Component Id="WTFragmentPSCore" Guid="{E4F5A6B7-8C9D-0E1F-A2B3-C4D5E6F7A8B9}"
                                Condition="WINDOWSTERMINAL">
                                <File Id="WTFragmentPSCoreFile"
                                    Source="$(var.SourceDir)_Fragments\AzureDevOpsShell-PSCore.json" />
                            </Component>
                            <Component Id="WTFragmentColorScheme" Guid="{F5A6B7C8-9D0E-1F2A-B3C4-D5E6F7A8B9C0}"
                                Condition="WINDOWSTERMINAL">
                                <File Id="WTFragmentColorSchemeFile"
                                    Source="$(var.SourceDir)_Fragments\AzureDevOpsShell-ColorScheme.json" />
                            </Component>
                        </Directory>
                    </Directory>
                </Directory>
            </Directory>
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ShortcutsFolder" Name="$(var.PRODUCTNAME)">
                <!-- Windows Terminal shortcut — Windows PowerShell profile -->
                <Component Id="ShellShortcutWT" Guid="{A1B2C3D4-5E6F-7890-ABCD-EF1234567890}"
                    Condition="WINDOWSTERMINAL">
                    <Shortcut Id="ShellIconShortcutWT" Name="Azure DevOps Shell"
                        Target="[LocalAppDataFolder]Microsoft\WindowsApps\wt.exe"
                        Directory="ShortcutsFolder"
                        Arguments="-p &quot;Azure DevOps Shell&quot;"
                        Icon="ProductIcon" />
                    <RemoveFolder Id="RemoveProgramMenuDirWT" On="uninstall"
                        Directory="ShortcutsFolder" />
                    <RegistryValue Root="HKCU" Key="Software\$(var.AUTHOR)\TfsCmdlets"
                        Name="InstalledWT"
                        Type="integer" Value="1" KeyPath="yes" />
                </Component>
                <!-- Windows Terminal shortcut — PowerShell Core profile -->
                <Component Id="ShellShortcutWTCore" Guid="{B2C3D4E5-6F70-8901-BCDE-F12345678901}"
                    Condition="WINDOWSTERMINAL">
                    <Shortcut Id="ShellIconShortcutWTCore" Name="Azure DevOps Shell (Core)"
                        Target="[LocalAppDataFolder]Microsoft\WindowsApps\wt.exe"
                        Directory="ShortcutsFolder"
                        Arguments="-p &quot;Azure DevOps Shell (Core)&quot;"
                        Icon="ProductIcon" />
                    <RegistryValue Root="HKCU" Key="Software\$(var.AUTHOR)\TfsCmdlets"
                        Name="InstalledWTCore"
                        Type="integer" Value="1" KeyPath="yes" />
                </Component>
                <!-- Legacy PowerShell shortcut (when WT is not detected) -->
                <Component Id="ShellShortcut" Guid="{9AB31DDC-700C-42A8-AF73-07FFFDF1BA15}"
                    Condition="NOT WINDOWSTERMINAL">
                    <Shortcut Id="ShellIconShortcut" Name="Azure DevOps Shell"
                        Target="[System64Folder]\WindowsPowerShell\v1.0\powershell.exe"
                        Directory="ShortcutsFolder"
                        Arguments="-noexit -command &quot;Import-Module TfsCmdlets -Version '$(var.PRODUCTVERSION)'; Enter-TfsShell&quot;"
                        Icon="ProductIcon" />
                    <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall"
                        Directory="ShortcutsFolder" />
                    <RegistryValue Root="HKCU" Key="Software\$(var.AUTHOR)\TfsCmdlets"
                        Name="Installed"
                        Type="integer" Value="1" KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <!-- Custom Actions -->

        <SetProperty Action="SetxCmdLine0" Id="QtExecCmdLine" Before="CallSetx" Sequence="execute"
            Value="&quot;setx.exe&quot; TFSCMDLETS 1" Condition="NOT Installed" />
        <SetProperty Action="SetxCmdLine1" Id="QtExecCmdLine" Before="CallSetx" Sequence="execute"
            Value="REG delete HKCU\Environment /F /V TFSCMDLETS"
            Condition="Installed AND NOT UPGRADINGPRODUCTCODE" />
        <CustomAction Id="CallSetx" DllEntry="WixQuietExec" Execute="immediate" Return="ignore"
            BinaryRef="Wix4UtilCA_X86" />

        <InstallExecuteSequence>
            <Custom Action="CallSetx" After="InstallFinalize" />
        </InstallExecuteSequence>

    </Package>

</Wix>